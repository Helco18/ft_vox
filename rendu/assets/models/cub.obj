# Cube CCW (Counterclockwise)
mtllib cub.mtl

v -0.5 -0.5 -0.5  # 1
v  0.5 -0.5 -0.5  # 2
v  0.5  0.5 -0.5  # 3
v -0.5  0.5 -0.5  # 4
v -0.5 -0.5  0.5  # 5
v  0.5 -0.5  0.5  # 6
v  0.5  0.5  0.5  # 7
v -0.5  0.5  0.5  # 8

# Texture coordinates
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

usemtl t_tree_Forest_c

# Faces (CCW order)
# Avant (+Z)
f 5/1 6/2 7/3 8/4
# Arrière (-Z)
f 2/1 1/2 4/3 3/4
# Droite (+X)
f 6/1 2/2 3/3 7/4
# Gauche (-X)
f 1/1 5/2 8/3 4/4
# Haut (+Y)
f 4/1 8/2 7/3 3/4
# Bas (-Y)
f 1/1 2/2 6/3 5/4
